# ============================================================================
# Variables de entorno para desplegar Empire Systems CRM en Railway.
# Copiá estas claves en Settings -> Variables del servicio (NO subas valores
# reales al repo). Las de la base de datos las provee el plugin MySQL de Railway.
# ============================================================================

# --- App -------------------------------------------------------------------
APP_NAME="Empire Systems"
APP_ENV=production
APP_DEBUG=false
# Generá una vez en local con: php artisan key:generate --show
APP_KEY=
# Dominio público del servicio (sin barra final). Ej. el que asigna Railway:
APP_URL=https://TU-APP.up.railway.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# --- Multi-tenant ----------------------------------------------------------
# Dominios que actúan como app CENTRAL (login, super_admin). Incluí el dominio
# de Railway y cualquier dominio propio central. Los dominios de cada TENANT no
# van aquí: se registran en la tabla `domains` y se añaden como dominio del
# servicio en Railway (Settings -> Networking -> Custom Domain).
CENTRAL_DOMAINS=TU-APP.up.railway.app

# --- Base de datos (MySQL de Railway) --------------------------------------
# Referenciá las variables del plugin MySQL con la sintaxis ${{...}} de Railway:
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# --- Sesión / cache / cola (driver database, sin Redis) --------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Almacenamiento (volumen de Railway montado en /app/storage) -----------
FILESYSTEM_DISK=local

# --- Logs ------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Mail (ajustá a tu proveedor real; por defecto queda en log) -----------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Otros -----------------------------------------------------------------
BCRYPT_ROUNDS=12
LORDICON_API_TOKEN=
